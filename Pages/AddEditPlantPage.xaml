<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:sf="clr-namespace:Syncfusion.Maui.Toolkit.TextInputLayout;assembly=Syncfusion.Maui.Toolkit"
             xmlns:sys="clr-namespace:System;assembly=netstandard"
             xmlns:pageModels="clr-namespace:HydroGrow.PageModels"
             x:Class="HydroGrow.Pages.AddEditPlantPage"
             x:DataType="pageModels:AddEditPlantPageModel"
             Title="{Binding PageTitle}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Anuluj" Command="{Binding CancelCommand}" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="{StaticResource LayoutPadding}" Spacing="12">

            <!-- Thumbnail picker -->
            <Border StrokeShape="RoundRectangle 16"
                    Stroke="{AppThemeBinding Light={StaticResource HydroGreen}, Dark={StaticResource HydroGreenDark}}"
                    StrokeThickness="1.5"
                    HeightRequest="160"
                    Padding="0"
                    Background="{AppThemeBinding Light={StaticResource LightSecondaryBackground}, Dark={StaticResource DarkSecondaryBackground}}">
                <Grid>
                    <!-- Placeholder: no photo -->
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="8"
                                         IsVisible="{Binding ThumbnailFullPath, Converter={StaticResource IsNullOrEmptyConverter}}">
                        <Image Source="{StaticResource IconImage}"
                               HeightRequest="36" WidthRequest="36"
                               HorizontalOptions="Center"
                               Opacity="0.7" />
                        <Label Text="Dotknij aby dodać zdjęcie"
                               Style="{StaticResource Caption1}"
                               TextColor="{AppThemeBinding Light={StaticResource HydroGreenDark}, Dark={StaticResource SecondaryDarkText}}"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>

                    <!-- Photo -->
                    <Image Source="{Binding ThumbnailFullPath}"
                           Aspect="AspectFill"
                           IsVisible="{Binding ThumbnailFullPath, Converter={StaticResource IsNotNullOrEmptyConverter}}" />

                    <!-- Edit overlay (bottom-right, visible when photo set) -->
                    <Border HorizontalOptions="End" VerticalOptions="End"
                            Margin="10"
                            IsVisible="{Binding ThumbnailFullPath, Converter={StaticResource IsNotNullOrEmptyConverter}}"
                            StrokeShape="RoundRectangle 20"
                            StrokeThickness="0"
                            BackgroundColor="#E6FFFFFF"
                            Padding="8">
                        <Image Source="{StaticResource IconPhoto}"
                               HeightRequest="20" WidthRequest="20" />
                    </Border>

                    <!-- Tap target -->
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SelectPhotoCommand}" />
                    </Grid.GestureRecognizers>
                </Grid>
            </Border>

            <!-- Name -->
            <sf:SfTextInputLayout Hint="Nazwa rośliny *">
                <Entry Text="{Binding Name}" ReturnType="Next" />
            </sf:SfTextInputLayout>

            <!-- Species -->
            <sf:SfTextInputLayout Hint="Gatunek (opcjonalnie)">
                <Entry Text="{Binding Species}" ReturnType="Next" />
            </sf:SfTextInputLayout>

            <!-- Location -->
            <sf:SfTextInputLayout Hint="Lokalizacja (opcjonalnie)">
                <Entry Text="{Binding Location}" ReturnType="Next" />
            </sf:SfTextInputLayout>

            <!-- Medium type -->
            <sf:SfTextInputLayout Hint="Typ podłoża">
                <Picker ItemsSource="{Binding MediumTypes}"
                        SelectedItem="{Binding SelectedMediumType}" />
            </sf:SfTextInputLayout>

            <!-- Acquired date -->
            <sf:SfTextInputLayout Hint="Data nabycia">
                <DatePicker Date="{Binding AcquiredDate}"
                            Format="d MMM yyyy"
                            MaximumDate="{x:Static sys:DateTime.Today}"
                            xmlns:sys="clr-namespace:System;assembly=netstandard" />
            </sf:SfTextInputLayout>

            <!-- Notes -->
            <sf:SfTextInputLayout Hint="Notatki">
                <Editor Text="{Binding Notes}"
                        AutoSize="TextChanges"
                        MinimumHeightRequest="80" />
            </sf:SfTextInputLayout>

            <!-- Save button -->
            <Button Text="Zapisz"
                    Command="{Binding SaveCommand}"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    CornerRadius="12"
                    HeightRequest="52"
                    HorizontalOptions="Fill"
                    Margin="0,8,0,0" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
