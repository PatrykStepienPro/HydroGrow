<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:pullToRefresh="clr-namespace:Syncfusion.Maui.Toolkit.PullToRefresh;assembly=Syncfusion.Maui.Toolkit"
             xmlns:pageModels="clr-namespace:HydroGrow.PageModels"
             xmlns:models="clr-namespace:HydroGrow.Models"
             x:Class="HydroGrow.Pages.DashboardPage"
             x:DataType="pageModels:DashboardPageModel"
             Title="HydroGrow">

    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior EventName="Appearing" Command="{Binding AppearingCommand}" />
    </ContentPage.Behaviors>

    <pullToRefresh:SfPullToRefresh IsRefreshing="{Binding IsRefreshing}"
                                   RefreshCommand="{Binding RefreshCommand}">
        <pullToRefresh:SfPullToRefresh.PullableContent>
            <ScrollView>
                <VerticalStackLayout Padding="{StaticResource LayoutPadding}" Spacing="{StaticResource LayoutSpacing}">

                    <!-- Summary row -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,8,0,4">
                        <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                            <VerticalStackLayout HorizontalOptions="Center">
                                <Label Text="{Binding TotalPlants}"
                                       Style="{StaticResource Title1}"
                                       TextColor="{StaticResource HydroGreen}"
                                       HorizontalOptions="Center" />
                                <Label Text="Rośliny"
                                       Style="{StaticResource Caption1}"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                            <VerticalStackLayout HorizontalOptions="Center">
                                <Label Text="{Binding AlertCount}"
                                       Style="{StaticResource Title1}"
                                       TextColor="{Binding AlertCount, Converter={StaticResource IntToAlertColorConverter}}"
                                       HorizontalOptions="Center" />
                                <Label Text="Alerty"
                                       Style="{StaticResource Caption1}"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!-- Plants needing attention -->
                    <Label Text="Wymagają uwagi"
                           Style="{StaticResource SectionHeaderStyle}"
                           IsVisible="{Binding PlantsNeedingAttention.Count, Converter={StaticResource IsNotZeroConverter}}" />

                    <CollectionView ItemsSource="{Binding PlantsNeedingAttention}"
                                    IsVisible="{Binding PlantsNeedingAttention.Count, Converter={StaticResource IsNotZeroConverter}}"
                                    SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:Plant">
                                <Border Style="{StaticResource AlertCardStyle}" Margin="0,2">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                                            <Label Text="{Binding Name}" Style="{StaticResource Body1Strong}" />
                                            <Label Text="{Binding Species}" Style="{StaticResource Caption1}"
                                                   TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />
                                        </VerticalStackLayout>
                                        <Label Grid.Column="1" Text="⚠"
                                               FontSize="20" TextColor="{StaticResource HydroRed}"
                                               VerticalOptions="Center" />
                                    </Grid>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type pageModels:DashboardPageModel}}, Path=NavigateToPlantCommand}"
                                                              CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Label Text="Wszystkie rośliny w dobrej kondycji ✓"
                           Style="{StaticResource Body2}"
                           TextColor="{StaticResource HydroGreen}"
                           HorizontalOptions="Center"
                           IsVisible="{Binding PlantsNeedingAttention.Count, Converter={StaticResource IsZeroConverter}}" />

                    <!-- Recent activity -->
                    <Label Text="Ostatnia aktywność"
                           Style="{StaticResource SectionHeaderStyle}"
                           IsVisible="{Binding RecentActivity.Count, Converter={StaticResource IsNotZeroConverter}}" />

                    <CollectionView ItemsSource="{Binding RecentActivity}"
                                    IsVisible="{Binding RecentActivity.Count, Converter={StaticResource IsNotZeroConverter}}"
                                    SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="pageModels:ActivityItem">
                                <Grid ColumnDefinitions="*,Auto" Padding="0,6" ColumnSpacing="8">
                                    <VerticalStackLayout Grid.Column="0">
                                        <Label Style="{StaticResource Caption1Strong}">
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="{Binding PlantName}" />
                                                    <Span Text=" — " />
                                                    <Span Text="{Binding Description}" />
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>
                                    </VerticalStackLayout>
                                    <Label Grid.Column="1"
                                           Text="{Binding RelativeTime}"
                                           Style="{StaticResource Caption2}"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}"
                                           VerticalOptions="Center" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- Empty state -->
                    <VerticalStackLayout IsVisible="{Binding RecentActivity.Count, Converter={StaticResource IsZeroConverter}}"
                                        Padding="0,32" HorizontalOptions="Center" Spacing="12">
                        <Label Text="🌱" FontSize="56" HorizontalOptions="Center" />
                        <Label Text="Brak aktywności"
                               Style="{StaticResource Title3}"
                               HorizontalOptions="Center" />
                        <Label Text="Dodaj pierwszą roślinę i zacznij monitorowanie"
                               Style="{StaticResource Body2}"
                               TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </ScrollView>
        </pullToRefresh:SfPullToRefresh.PullableContent>
    </pullToRefresh:SfPullToRefresh>

</ContentPage>
