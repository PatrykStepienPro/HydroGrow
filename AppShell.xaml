<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="HydroGrow.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:HydroGrow.Pages"
    FlyoutBehavior="Disabled"
    Title="HydroGrow">

    <TabBar>
        <ShellContent
            Title="Dashboard"
            Icon="{StaticResource IconDashboard}"
            ContentTemplate="{DataTemplate pages:DashboardPage}"
            Route="dashboard" />

        <ShellContent
            Title="Rośliny"
            Icon="{StaticResource IconPlants}"
            ContentTemplate="{DataTemplate pages:PlantListPage}"
            Route="plants" />

        <ShellContent
            Title="Przypomnienia"
            Icon="{StaticResource IconReminders}"
            ContentTemplate="{DataTemplate pages:RemindersPage}"
            Route="reminders" />

        <ShellContent
            Title="Ustawienia"
            Icon="{StaticResource IconSettings}"
            ContentTemplate="{DataTemplate pages:SettingsPage}"
            Route="settings" />
    </TabBar>

</Shell>
