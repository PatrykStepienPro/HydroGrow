<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:HydroGrow"
             x:Class="HydroGrow.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
                <ResourceDictionary Source="Resources/Styles/AppStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <utilities:IsNotNullOrEmptyConverter x:Key="IsNotNullOrEmptyConverter"
                xmlns:utilities="clr-namespace:HydroGrow.Utilities" />
            <utilities:IsNullOrEmptyConverter x:Key="IsNullOrEmptyConverter"
                xmlns:utilities="clr-namespace:HydroGrow.Utilities" />
            <utilities:IsNotZeroConverter x:Key="IsNotZeroConverter"
                xmlns:utilities="clr-namespace:HydroGrow.Utilities" />
            <utilities:IsZeroConverter x:Key="IsZeroConverter"
                xmlns:utilities="clr-namespace:HydroGrow.Utilities" />
            <utilities:IntToAlertColorConverter x:Key="IntToAlertColorConverter"
                xmlns:utilities="clr-namespace:HydroGrow.Utilities" />
            <utilities:BoolToOverdueColorConverter x:Key="BoolToOverdueColorConverter"
                xmlns:utilities="clr-namespace:HydroGrow.Utilities" />
            <utilities:BoolToAlertColorConverter x:Key="BoolToAlertColorConverter"
                xmlns:utilities="clr-namespace:HydroGrow.Utilities" />
            <utilities:NullableDoubleToStringConverter x:Key="NullableDoubleToStringConverter"
                xmlns:utilities="clr-namespace:HydroGrow.Utilities" />
            <utilities:PhotoPathConverter x:Key="PhotoPathConverter"
                xmlns:utilities="clr-namespace:HydroGrow.Utilities" />
            <utilities:InvertedBoolConverter x:Key="InvertedBoolConverter"
                xmlns:utilities="clr-namespace:HydroGrow.Utilities" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
